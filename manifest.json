{
  "manifest_version": 3,
  "name": "Moodle Hoarder",
  "version": "2.8.3",
  "key": "",
  "description": "Hoards every file, folder, assignment, syllabus and recording link from Ariel Moodle courses into tidy ZIPs. Plus Zoom cloud recording links.",
  "permissions": ["activeTab", "downloads", "scripting", "notifications", "storage", "unlimitedStorage", "contextMenus", "debugger", "offscreen", "declarativeNetRequest", "nativeMessaging"],
  "host_permissions": [
    "https://moodlearn.ariel.ac.il/*",
    "https://*.ariel.ac.il/*",
    "https://zoom.us/*",
    "https://*.zoom.us/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://moodlearn.ariel.ac.il/my/*"],
      "js": ["settings.js", "i18n.js", "content_dashboard.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Moodle Hoarder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
